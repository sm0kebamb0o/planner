; T
[IS (А Б В) (А Б В)]

; ()
[IS (ЯЗЫК АДА) (ЯЗЫК АДЫ)]

; prints К.ПРУТКОВ, result: БДИ!
[PROG (X Y)
  [IS (*X ГОВОРИЛ: *Y) (К.ПРУТКОВ ГОВОРИЛ: БДИ!)]
  [PRINT .X]
  .Y]

; T
[IS ((А Б) В) ((А Б) В)]

; ()
[IS (А Б) (А Б В)]

; T
[PROG (X)
  [IS (.X .X) (ОДИН ОДИН)]]

; T
[PROG (X)
  [IS (.X А .X) (Б А Б)]]
