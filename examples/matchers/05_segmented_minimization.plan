; prints (), А, result: (+ Б + В)
[PROG (X Y Z)
  [IS (!*X *Y !*Z) (А + Б + В)]
  [PRINT .X]
  [PRINT .Y]
  .Z]

; prints (1 2), (3), result: (4 5 6)
[PROG (А Б В)
  [IS (!*А + !*Б + !*В) (1 2 + 3 + 4 5 6)]
  [PRINT .А]
  [PRINT .Б]
  .В]

; prints (), (), result: ()
[PROG (X Y Z)
  [IS (!*X А !*Y Б !*Z) (А Б)]
  [PRINT .X]
  [PRINT .Y]
  .Z]
