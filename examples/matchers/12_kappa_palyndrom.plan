[DEFINE PALYNDROM (KAPPA ()
  [AUT ()
       [LIST 1]
       [SAME (X) (*X <PALYNDROM> .X)]])]

; T
[IS [PALYNDROM] ()]

; T
[IS [PALYNDROM] (А)]

; T
[IS [PALYNDROM] (А А)]

; ()
[IS [PALYNDROM] (А Б)]

; T
[IS [PALYNDROM] (А Б А)]

; ()
[IS [PALYNDROM] (А Б В)]

; T
[IS [PALYNDROM] (А Б Б А)]

; T
[IS [PALYNDROM] (1 2 3 2 1)]

; ()
[IS [PALYNDROM] (1 2 3 4 5)]
