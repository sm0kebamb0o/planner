; prints (1), result: (2 + 3 + 4)
[PROG (X Y)
  [IS (!*X + !*Y) (1 + 2 + 3 + 4)]
  [PRINT .X]
  .Y]

; prints (+ 2 + 3 +), result: 4
[PROG (X Y)
  [IS (1 !*X *Y) (1 + 2 + 3 + 4)]
  [PRINT .X]
  .Y]

; prints (А Б), result: (В Г = Д)
[PROG (ДО ПОСЛЕ)
  [IS (!*ДО = !*ПОСЛЕ) (А Б = В Г = Д)]
  [PRINT .ДО]
  .ПОСЛЕ]

; result: (А)
[PROG (X)
  [IS (!.X Б) (А Б)]
  .X]

; T
[PROG (X)
  [SET X (А)]
  [IS (!.X Б) (А Б)]]
