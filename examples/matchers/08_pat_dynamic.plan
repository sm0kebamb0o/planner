; T
[PROG (P)
  [SET P HELLO]
  [IS [PAT .P] HELLO]]

; T
[PROG (P)
  [SET P 42]
  [IS [PAT .P] 42]]

; ()
[PROG (P)
  [SET P 5]
  [IS [PAT .P] 7]]

; T
[PROG (ПРЕДЕЛ)
  [SET ПРЕДЕЛ 10]
  [IS [ET [NUM] [PAT .ПРЕДЕЛ]] 10]]

[CSET МАКС 100]
; T
[IS [PAT :МАКС] 100]
; ()
[IS [PAT :МАКС] 99]

; prints T, result: ()
[PROG (ТЕКУЩИЙ)
  [SET ТЕКУЩИЙ А]
  [PRINT [IS [PAT .ТЕКУЩИЙ] А]]
  [SET ТЕКУЩИЙ Б]
  [IS [PAT .ТЕКУЩИЙ] А]]
